{
  "name": "cw-cat",
  "version": "0.2.0-beta.6",
  "description": "CW Skimmer for FlexRadio 6000 — decodes CW signals from DAX IQ and reports spots",
  "author": {
    "name": "Casey Stanton"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "fft.js": "^4.0.4"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.waffleslop.cwcat",
    "productName": "CW CAT",
    "icon": "assets/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "worker/**/*",
      "renderer/**/*",
      "assets/icon.png",
      "assets/cty.dat",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "CW-CAT-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CW CAT"
    },
    "portable": {
      "artifactName": "CW-CAT-${version}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Waffleslop",
      "repo": "cw-cat"
    }
  }
}
